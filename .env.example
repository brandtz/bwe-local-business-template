# BWE Local Business Website Template — Environment variables
# Copy to .env.local for dev. Set these in Netlify site settings for deploys.

# Which client config to load (maps to /clients/<CLIENT>/)
CLIENT=superior-exteriors

# Sanity — leave empty to use seed data fallback from /clients/<CLIENT>/content/seed.ts
SANITY_PROJECT_ID=
SANITY_DATASET=production

# Cal.com — base URL for the client's Cal.com account (e.g., https://cal.com/superior-exteriors)
CAL_COM_BASE_URL=

# Resend — server-only. Required for the contact form to actually send email.
RESEND_API_KEY=

# Public site URL — used for absolute links in SEO / JSON-LD. Netlify injects URL automatically.
SITE_URL=http://localhost:3000
